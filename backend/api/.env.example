# Server
PORT=3001
NODE_ENV=development

# Database (Render provides this)
DATABASE_URL=postgresql://user:password@host:5432/gamearena

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayHero (M-Pesa STK Push)
PAYHERO_API_KEY=your-payhero-api-key
PAYHERO_API_URL=https://api.payhero.co.ke/v2

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# App
APP_NAME=GameArena
APP_URL=https://your-app.onrender.com
ADMIN_URL=https://your-admin.onrender.com
